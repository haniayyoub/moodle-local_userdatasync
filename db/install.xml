<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/userdatasync/db" VERSION="2026052500" COMMENT="XMLDB file for local_userdatasync"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
    <TABLES>
        <TABLE NAME="local_userdatasync_log" COMMENT="Log records for user data sync operations">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="username" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="fieldname" TYPE="char" LENGTH="100" NOTNULL="false"/>
                <FIELD NAME="oldvalue" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="newvalue" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="status" TYPE="char" LENGTH="50" NOTNULL="true"/>
                <FIELD NAME="message" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
                <INDEX NAME="username_idx" UNIQUE="false" FIELDS="username"/>
                <INDEX NAME="fieldname_idx" UNIQUE="false" FIELDS="fieldname"/>
                <INDEX NAME="status_idx" UNIQUE="false" FIELDS="status"/>
                <INDEX NAME="timecreated_idx" UNIQUE="false" FIELDS="timecreated"/>
            </INDEXES>
        </TABLE>
    </TABLES>
</XMLDB>
